# Frontrun MCP Server Configuration
#
# Easiest path: skip this file entirely and run `npx frontrun-mcp-server --login`
# (OAuth flow — credentials saved to ~/.frontrun/credentials.json).

# Your Frontrun API key (frontrun.vc → Settings → API Keys)
FRONTRUN_API_KEY=sig_your_key_here

# Optional: override the API base URL (defaults to production)
# FRONTRUN_API_URL=https://signal-production-0952.up.railway.app
